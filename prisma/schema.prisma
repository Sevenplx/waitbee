generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  passwordHash String       @map("password_hash")
  createdAt    DateTime     @default(now()) @map("created_at")
  sessions     Session[]
  resetTokens  ResetToken[]
  waitlists    Waitlist[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model ResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reset_tokens")
}

model Waitlist {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  productName    String       @map("product_name")
  description    String
  slug           String       @unique
  buttonText     String       @map("button_text")
  bgColor        String       @map("bg_color")
  maxSubscribers Int          @default(100) @map("max_subscribers")
  createdAt      DateTime     @default(now()) @map("created_at")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscribers    Subscriber[]

  @@map("waitlists")
}

model Subscriber {
  id         String   @id @default(uuid()) @db.Uuid
  waitlistId String   @map("waitlist_id") @db.Uuid
  email      String
  createdAt  DateTime @default(now()) @map("created_at")
  waitlist   Waitlist @relation(fields: [waitlistId], references: [id], onDelete: Cascade)

  @@unique([waitlistId, email])
  @@map("subscribers")
}
